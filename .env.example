# =========================
# KwikKhata Environment
# =========================

# --- App/API ---
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
DATA_BACKEND=excel
WEBHOOK_RATE_LIMIT_PER_MINUTE=120
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60
WEBHOOK_MAX_PAYLOAD_KB=256
PII_HASH_SALT=
DASHBOARD_TOKEN=
DEFAULT_RESPONSE_MODE=rich

# --- Storage Backend ---
# Use when DATA_BACKEND=postgres
KWIKKHATA_DATABASE_URL=
KWIKKHATA_SHOP_NAME=Default Shop

# --- AI Parsing ---
AI_PROVIDER=ollama
FALLBACK_PROVIDER=gemini
ENABLE_FALLBACK=true
PARSER_MODE=hybrid

# Ollama (local)
OLLAMA_MODEL=llama3.2:latest
OLLAMA_URL=http://127.0.0.1:11434/api/generate

# Gemini
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=

# Optional OpenAI (future STT/voice pipeline)
OPENAI_API_KEY=
WHISPER_MODEL=gpt-4o-mini-transcribe

# --- WhatsApp Cloud API (future Zero-UI agent) ---
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_GRAPH_VERSION=v21.0
WHATSAPP_API_BASE=https://graph.facebook.com
OWNER_WHATSAPP_NUMBER=
CUSTOMER_PHONEBOOK=
CUSTOMER_PHONEBOOK_B64=

# --- Automation Defaults (future reminders) ---
REMINDER_RUN_TIME=10:00
REMINDER_MIN_DAYS=15
REMINDER_MIN_AMOUNT=500
DEFAULT_COUNTRY_CODE=+91

# --- Backup ---
KWIKKHATA_ENABLE_BACKUP=true
KWIKKHATA_BACKUP_DIR=backups
KWIKKHATA_BACKUP_KEEP=20
